{
  "name": "jenkins-client",
  "displayName": "Jenkins Client",
  "icon": "icon.png",
  "publisher": "lightning1377",
  "description": "Show Jenkins build results for current git branch",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lightning1377/jenkins-client.git"
  },
  "bugs": {
    "url": "https://github.com/lightning1377/jenkins-client/issues"
  },
  "homepage": "https://github.com/lightning1377/jenkins-client#readme",
  "keywords": [
    "jenkins",
    "build-status",
    "ci",
    "git",
    "statusbar",
    "vscode-extension"
  ],
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jenkins-client.showBuildStatus",
        "title": "Show Jenkins Client Status",
        "category": "Jenkins",
        "icon": "$(git-fetch)"
      },
      {
        "command": "jenkins-client.clearJenkinsServiceCache",
        "title": "Clear Jenkins Service Cache",
        "category": "Jenkins",
        "icon": "$(trash)"
      },
      {
        "command": "jenkins-client.setApiToken",
        "title": "Set Jenkins API Token",
        "category": "Jenkins",
        "icon": "$(key)"
      },
      {
        "command": "jenkins-client.clearApiToken",
        "title": "Clear Jenkins API Token",
        "category": "Jenkins",
        "icon": "$(trash)"
      },
      {
        "command": "jenkins-client.openQuickPick",
        "title": "Open Jenkins Quick Pick Menu",
        "enablement": "false"
      }
    ],
    "configuration": {
      "title": "Jenkins Client",
      "properties": {
        "jenkinsBuildStatus.jenkinsUrl": {
          "type": "string",
          "default": "",
          "description": "Jenkins server URL"
        },
        "jenkinsBuildStatus.username": {
          "type": "string",
          "default": "",
          "description": "Jenkins username"
        },
        "jenkinsBuildStatus.jobName": {
          "type": "string",
          "default": "",
          "description": "Jenkins Job Name (Branches not specified in branchSpecificJobs are expected to be built by this job)"
        },
        "jenkinsBuildStatus.branchSpecificJobs": {
          "type": "object",
          "default": {},
          "description": "Branch Specific Jobs (In case some branches are built using a job name other than the one specified in jobName field)"
        },
        "jenkinsBuildStatus.minPollWaitTime": {
          "type": "integer",
          "default": 5,
          "description": "Minimum time in seconds to wait between build detail fetches when build is in progress"
        },
        "jenkinsBuildStatus.maxPollCount": {
          "type": "integer",
          "default": 60,
          "description": "Maximum number of times to fetch build details when build is in progress"
        },
        "jenkinsBuildStatus.excludeBranches": {
          "type": "array",
          "default": [],
          "description": "Specify branches which are not built by any job"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "rimraf out/** && tsc -p ./",
    "lint": "eslint src --ext ts",
    "watch": "tsc -watch -p ./",
    "vsce": "node scripts/package-vsix.js",
    "check-release-tag": "node scripts/check-release-tag.js"
  },
  "devDependencies": {
    "@types/node": "^20.4.5",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^8.57.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "simple-git": "^3.19.1"
  }
}
